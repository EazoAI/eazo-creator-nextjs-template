# Eazo Private Key to decrypt the user session token (Eazo Mobile environment)
EAZO_PRIVATE_KEY=your_eazo_private_key_here

# PostgreSQL connection string (used by Drizzle ORM)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/myapp

# GenAuth (Authing) — required for web login
# App ID and domain from your GenAuth console
NEXT_PUBLIC_GENAUTH_APP_ID=your_authing_app_id
NEXT_PUBLIC_GENAUTH_APP_DOMAIN=https://your-tenant.genauth.ai
# JWKS endpoint is derived automatically: ${DOMAIN}/oidc/.well-known/jwks.json
# No extra env var needed — just set the domain above.
